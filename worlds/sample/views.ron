[
    (
        id: "arrival_street",
        title: "Island Harbor Crossing",
        description: "Salt wind moves through a small island harbor crossing. The black-stone noren of an izakaya hangs on the west lane, the Island Trade Guild keeps a quiet counter south of the junction, and a weathered bulletin board stands below it. New arrivals must read the board agreement before the wider world opens.",
        ascii_art: [
            "============================================================",
            "                  ISLAND HARBOR CROSSING",
            "============================================================",
            "",
            "                            north path",
            "                               |",
            "                               |",
            "       [Blackstone] ------- <Me>",
            "          |                    |",
            "    harbor lane             [Guild]",
            "                               |",
            "                         {bulletin board}",
            "                               |",
            "                            south path",
        ],
        exits: [
            (
                direction: north,
                target: "street_north_01",
                label: Some("north island market path"),
                requirements: [],
            ),
            (
                direction: south,
                target: "street_south_01",
                label: Some("south island market path"),
                requirements: [],
            ),
            (
                direction: west,
                target: "west_main_street",
                label: Some("harbor lane"),
                requirements: [],
            ),
        ],
        entities: ["tavern_front", "chamber_of_commerce", "cyber_scroll_board"],
        layout: None,
    ),
