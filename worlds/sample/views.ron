    (
        id: "west_main_street",
        title: "Blackstone Izakaya",
        description: "A low izakaya opens behind a black basalt threshold near the harbor lane. Noren cloth stirs in the sea air, cedar beams hold the smell of smoke, and rainwater ticks from iron hooks by the door. The counter is worn smooth by cups, coins, and old arguments. The keeper looks like a very good person; order the house drink with /buy beer and talk with him.",
        ascii_art: [
            "============================================================",
            "                    BLACKSTONE IZAKAYA",
            "============================================================",
            "                           {drink menu}",
            "                                  |",
            "            [cedar counter] -- <Me> -- east to harbor crossing",
            "                                  |",
            "                         Blackstone keeper",
        ],
        exits: [
            (
                direction: east,
                target: "arrival_street",
                label: Some("toward the harbor crossing"),
                requirements: [],
            ),
        ],
        entities: ["blackstone_bartender", "blackstone_menu"],
        layout: None,
    ),
